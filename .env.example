# Copy this file to .env and set your values.
# Do not commit .env with real secrets.

# Parser key (used when PARSER_BACKEND="openai")
OPENAI_API_KEY_PARSER="sk-your-parser-key"

# Fallback key (used by code interpreter fallback)
OPENAI_API_KEY_FALLBACK="sk-your-fallback-key"

# Optional backward-compatible shared key (used if specific keys are not set)
# OPENAI_API_KEY="sk-your-shared-key"
